# 디스코드 봇 토큰 (Discord Developer Portal에서 발급)
DISCORD_TOKEN=

# 랭크 데이터 소스: dakgg(크롤링, 임시용) 또는 official(공식 API, 발급 후 전환)
RANK_SOURCE=dakgg

# dak.gg 전적 갱신 버튼 자동클릭 여부 (true/false). 속도가 중요하면 false 추천
# (특히 Render 무료 티어처럼 CPU/메모리가 적은 환경에서는 false로 두는 걸 강력 추천)
DAKGG_AUTO_REFRESH=true

# 공식 API 키 (developer.eternalreturn.io 에서 발급, RANK_SOURCE=official일 때만 필요)
OFFICIAL_API_KEY=

# 관리자 명령을 쓸 수 있는 역할 이름 (비워두면 '서버 관리' 권한 보유자만 허용)
ADMIN_ROLE_NAME=

# 개발/테스트용 서버(길드) ID. 설정하면 그 서버에만 슬래시 커맨드가 즉시 반영됨
# (안 채우면 전역 동기화라 디스코드에 반영되기까지 최대 1시간 걸릴 수 있음)
# 서버 ID 구하는 법: 디스코드 설정 > 고급 > 개발자 모드 켜기 → 서버 아이콘 우클릭 → "서버 ID 복사"
TEST_GUILD_ID=
